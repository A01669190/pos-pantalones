<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>POS Pantalones</title>
    <style>
        .product-card { cursor: pointer; border: none; shadow: 0 2px 5px rgba(0,0,0,0.1); transition: 0.2s; }
        .product-card:hover { transform: scale(1.02); }
        .img-container { height: 120px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #eee; }
        .img-container img { width: 100%; height: auto; }
        #cart-sticky { position: sticky; top: 20px; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); height: 85vh; display: flex; flex-direction: column; }
    </style>
</head>
<body class="bg-light">

<div class="container-fluid p-4">
    <div class="row">
        <div class="col-md-8">
            <div class="d-flex mb-3 gap-2">
                <input type="text" id="scanner" class="form-control form-control-lg shadow-sm" placeholder="🔍 Escanea o busca pantalón..." autofocus>
                <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#modalNuevo">+ Nuevo</button>
            </div>

            <div class="row g-3">
                <% productos.forEach(p => { %>
                    <div class="col-6 col-md-3">
                        <div class="card product-card h-100" onclick="agregarAlCarrito('<%= p.codigo %>', '<%= p.nombre %>', <%= p.precio %>)">
                            <div class="img-container">
                                <img src="<%= p.imagen %>" onerror="this.src='https://via.placeholder.com/150?text=Ropa'">
                            </div>
                            <div class="card-body p-2 text-center">
                                <small class="text-muted d-block"><%= p.codigo %></small>
                                <strong><%= p.nombre %></strong>
                                <h5 class="text-primary mt-1">$<%= p.precio %></h5>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col-md-4">
            <div id="cart-sticky">
                <h4>Venta Actual</h4>
                <div class="flex-grow-1 overflow-auto">
                    <table class="table align-middle">
                        <tbody id="lista-carrito"></tbody>
                    </table>
                </div>
                <div class="border-top pt-3">
                    <div class="d-flex justify-content-between h4">
                        <span>Total:</span> <span id="total-text">$0.00</span>
                    </div>
                    <button class="btn btn-success w-100 btn-lg mt-2" onclick="cobrar()">PAGAR Y REGISTRAR</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNuevo" tabindex="-1">
  <div class="modal-dialog">
    <form class="modal-content" action="/agregar" method="POST" enctype="multipart/form-data">
      <div class="modal-header"><h5>Registrar Nuevo Pantalón</h5></div>
      <div class="modal-body">
          <input type="text" name="codigo" class="form-control mb-2" placeholder="Código (Escanea aquí)" required>
          <input type="text" name="nombre" class="form-control mb-2" placeholder="Nombre (Ej: Jean Levi's Azul)" required>
          <input type="number" name="precio" class="form-control mb-2" placeholder="Precio de venta" required>
          <input type="number" name="stock" class="form-control mb-2" placeholder="Cantidad en bodega" required>
          <label class="small text-muted">Foto del pantalón:</label>
          <input type="file" name="foto" class="form-control" accept="image/*">
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary w-100">Guardar Producto</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    let carrito = [];
    const scanInput = document.getElementById('scanner');

    // Función del escáner
    scanInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            fetch(`/api/producto/${scanInput.value}`)
                .then(res => res.json())
                .then(p => {
                    if (p.error) alert("Pantalón no registrado.");
                    else agregarAlCarrito(p.codigo, p.nombre, p.precio);
                    scanInput.value = '';
                });
        }
    });

    function agregarAlCarrito(codigo, nombre, precio) {
        const existe = carrito.find(i => i.codigo === codigo);
        if (existe) existe.cantidad++;
        else carrito.push({ codigo, nombre, precio, cantidad: 1 });
        render();
    }

    function render() {
        const lista = document.getElementById('lista-carrito');
        lista.innerHTML = '';
        let suma = 0;
        carrito.forEach((item, index) => {
            suma += item.precio * item.cantidad;
            lista.innerHTML += `<tr>
                <td>${item.nombre}</td>
                <td>x${item.cantidad}</td>
                <td>$${item.precio * item.cantidad}</td>
                <td><button class="btn btn-sm btn-outline-danger" onclick="carrito.splice(${index},1);render()">x</button></td>
            </tr>`;
        });
        document.getElementById('total-text').innerText = '$' + suma.toFixed(2);
    }

    function cobrar() {
        if(carrito.length === 0) return;
        alert("Venta procesada con éxito.");
        location.reload(); // En un sistema real aquí enviarías el POST al servidor
    }
</script>
</body>
</html>